# Copy to .env.local and fill in. Never commit real values.

# --- Supabase ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Bypasses row-level security. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Public base URL for emailed links (invites, password resets), no trailing slash.
# Optional: on Vercel this defaults to the production domain automatically.
# Set it only to override, e.g. a custom domain: https://prayer.example.com
NEXT_PUBLIC_SITE_URL=

# --- Notifications (email) ---
# Resend API key for transactional notification emails (separate from the
# Supabase Auth SMTP settings used for invites/resets). From resend.com → API Keys.
RESEND_API_KEY=
# From address for notifications. Must be on a Resend-verified domain.
# Optional; defaults to "Redemption Church Seattle <prayer@redemptionseattle.org>".
NOTIFY_FROM_EMAIL=
# Shared secret guarding the digest cron route. Generate a long random string and
# set the same value in the Vercel Cron job's Authorization header.
CRON_SECRET=

# --- Twilio ---
# From the Twilio Console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio phone number that receives requests and sends replies, e.g. +15551234567
TWILIO_PHONE_NUMBER=
# Public URL Twilio posts inbound SMS to, e.g. https://your-app.vercel.app/api/sms
# Used to validate inbound webhook signatures. If unset, the host header is used.
TWILIO_WEBHOOK_URL=
